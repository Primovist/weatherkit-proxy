{
    "version": 2,
    "builds": [
        {
            "src": "src/Vercel.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        { "src": "/", "dest": "src/Vercel.js" },
        { "src": "/conf/(.*)", "dest": "src/Vercel.js" },
        { "src": "/p/(.*)", "dest": "src/Vercel.js" },
        { "src": "/api/v1/availability/(.*)", "dest": "src/Vercel.js" },
        { "src": "/api/v1/airQualityScale/(.*)", "dest": "src/Vercel.js" },
        { "src": "/api/v2/weather/(.*)", "dest": "src/Vercel.js" },
        { "src": "/(.*)", "status": 404 }
    ]
}
